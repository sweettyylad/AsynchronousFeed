# --- обязательные ---
# Токен стороннего Image Search API (заголовок X-API-Token)
IMAGE_API_TOKEN=

# PostgreSQL. Для docker compose менять не нужно (совпадает с сервисом postgres).
DATABASE_URL=postgresql://app:app@postgres:5432/image_feed

# --- опциональные (значения по умолчанию) ---
# NODE_ENV=production
# PORT=3000
# IMAGE_API_BASE_URL=https://service.test.elvetech.io
# CACHE_TTL_SECONDS=3600
# UPSTREAM_TIMEOUT_MS=60000
# UPSTREAM_RETRY_ATTEMPTS=3
# PENDING_STALE_SECONDS=120
# LOG_LEVEL=info

# --- используются только docker-compose (сервис postgres) ---
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=image_feed
